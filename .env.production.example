# DeepSeek API Service - Production Environment Variables
# Copy these to your deployment platform (Railway/Render/Fly.io)

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Server
PORT=3456
NODE_ENV=production

# Admin (CHANGE THIS to a strong random value!)
ADMIN_PASSWORD=change-me-to-random

# Database path (for persistent volume)
DB_PATH=/app/data/data.db

# Manual payment info (shown to users on recharge page)
MANUAL_PAYMENT_INFO=微信：xxxxxxxxx\n支付宝：xxxxxxxxx\n转账后请提交凭证，管理员确认后到账。

# XorPay (optional - leave empty if not using)
XORPAY_APP_ID=
XORPAY_APP_SECRET=
XORPAY_NOTIFY_URL=
