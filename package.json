{
  "name": "deepseek-api-service",
  "version": "1.0.0",
  "description": "DeepSeek API转售服务 - 封装垂直场景专用API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "set NODE_ENV=production&& node server.js",
    "dev": "node --watch server.js",
    "init-db": "node -e \"require('./db').init()\"",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "localtunnel": "^2.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sql.js": "^1.12.0",
    "uuid": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
