# DeepSeek API Configuration
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Server
PORT=3456
NODE_ENV=development

# Admin
# Generate a strong password: openssl rand -hex 32
ADMIN_PASSWORD=change-me-to-a-strong-random-value

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_AI=30
RATE_LIMIT_MAX_AUTH=10

# Request Size
MAX_BODY_SIZE=100kb

# XorPay Payment (register at xorpay.com)
XORPAY_APP_ID=your_xorpay_app_id
XORPAY_APP_SECRET=your_xorpay_app_secret
XORPAY_NOTIFY_URL=https://your-domain.com/api/payments/notify

# Points Packages (JSON array, modify pricing as needed)
# POINTS_PACKAGES=[{"id":"basic","label":"基础包","amount":10,"points":1000,"bonus":0}]

# Payment
PAYMENT_ORDER_EXPIRY_MINUTES=30

# DeepSeek API Timeout (ms)
DEEPSEEK_TIMEOUT_MS=30000
